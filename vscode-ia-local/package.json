{
  "name": "vscode-ia-local",
  "displayName": "IA Local Chat",
  "description": "Chat de IA local desde VS Code usando tu backend Ollama Proxy",
  "version": "0.0.1",
  "publisher": "yoniquer",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:iaLocal.openChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "iaLocal.openChat",
        "title": "IA Local: Abrir Chat"
      }
    ],
    "configuration": {
      "title": "IA Local",
      "properties": {
        "iaLocal.apiBaseUrl": {
          "type": "string",
          "default": "https://ollama-proxy-api.vercel.app",
          "description": "URL base de tu API (sin barra final)."
        },
        "iaLocal.defaultModel": {
          "type": "string",
          "default": "llama3:8b",
          "description": "Modelo por defecto para enviar prompts."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3"
  }
}
